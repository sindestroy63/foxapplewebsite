POSTGRES_DB=foxapple
POSTGRES_USER=foxapple
POSTGRES_PASSWORD=change_me_strong_password

DATABASE_URL=postgres://foxapple:change_me_strong_password@postgres:5432/foxapple
PAYLOAD_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Публичный базовый URL сайта и Payload-сервера. Используйте технический (punycode) вид домена —
# кириллица в ENV/CORS/CSRF недопустима. Для локальной разработки оставьте http://localhost.
# Production-пример: https://xn--n1aagcfji.xn--p1ai (= https://фохстор.рф)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost
NEXT_PUBLIC_SITE_URL=http://localhost

# Дополнительные разрешённые origin для Payload CORS/CSRF через запятую (необязательно).
# По умолчанию уже разрешены: серверный URL выше, xn--n1aagcfji.xn--p1ai (+ www) и localhost.
# PAYLOAD_ALLOWED_ORIGINS=https://example.com,https://www.example.com

RUN_MIGRATIONS_ON_START=true
PAYLOAD_SEED_ON_START=true

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# Необязательно: кастомный базовый URL Telegram Bot API (например, для прокси в закрытой сети)
TELEGRAM_API_BASE=
